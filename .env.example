# GitHub OAuth2 app credentials (create at https://github.com/settings/developers)
# Callback URL for local dev: http://localhost:8080/login/oauth2/code/github
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here

# Where Spring Security redirects the browser after a successful OAuth2 login.
# Dev: http://localhost:5173/  (Vite SPA)
# Prod: https://your-domain.com/
OAUTH2_SUCCESS_REDIRECT_URL=http://localhost:5173/

# Postgres credentials (defaults work for local Docker Compose)
DB_USERNAME=postgres
DB_PASSWORD=postgres
R2DBC_URL=r2dbc:postgresql://localhost:5432/realtimechat

# Rate limiting: max messages per second per authenticated user (default: 3)
RATE_LIMIT_MSG_PER_SEC=3
